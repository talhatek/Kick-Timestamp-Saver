{
  "manifest_version": 3,
  "name": "Kick Timestamp Saver",
  "version": "1.1",
  "description": "Easily save your current timestamp while watching Kick streams or VODs.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-timestamp": {
      "suggested_key": {
        "default": "Alt+K",
        "mac": "Command+Shift+K"
      },
      "description": "Quick save current Kick timestamp"
    }
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "*://*.kick.com/*"
  ]
}