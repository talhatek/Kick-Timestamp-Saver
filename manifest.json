{
  "manifest_version": 3,
  "name": "Kick Timestamp Saver",
  "version": "1.3",
  "description": "Easily save your current timestamp while watching Kick streams or VODs.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.kick.com/*"],
      "js": ["utils.js", "content.js"]
    }
  ],
  "commands": {
    "save-timestamp": {
      "suggested_key": {
        "default": "Alt+K",
        "mac": "Command+Shift+K"
      },
      "description": "Quick save current Kick timestamp"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "*://*.kick.com/*"
  ]
}
